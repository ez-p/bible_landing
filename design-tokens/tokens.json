{
  "name": "Reverent Classic",
  "description": "Warm parchment-and-gold color palette for Paul's Bible Study (paulpowell.cc). Source of truth: app/globals.css in the bible_landing repo.",
  "color": {
    "bg-parchment-start": { "value": "#f6eed7", "usage": "Page background gradient start" },
    "bg-parchment-mid":   { "value": "#efe5c9", "usage": "Page background gradient mid" },
    "bg-parchment-end":   { "value": "#e9ddbe", "usage": "Page background gradient end" },
    "text-primary":       { "value": "#2c2a20", "usage": "Default body text" },
    "text-heading":       { "value": "#1c2b49", "usage": "Headings (navy)" },
    "text-muted":         { "value": "#5c5843", "usage": "Subtitles, descriptions" },
    "text-footer":        { "value": "#8a856d", "usage": "Footer text" },
    "olive":              { "value": "#4d5330", "usage": "Primary accent panel background" },
    "parchment-light":    { "value": "#f4ecd6", "usage": "Text on olive panel" },
    "gold":               { "value": "#bd9a5f", "usage": "Decorative rules, borders, accents" },
    "gold-muted":         { "value": "#c9b47e", "usage": "Secondary label on olive panel" },
    "card-bg":            { "value": "#faf4e2", "usage": "Card/panel background" },
    "eyebrow":            { "value": "#6b7144", "usage": "Small uppercase label text" },
    "eyebrow-tools":      { "value": "#8a6b3f", "usage": "Section heading label" },
    "cta":                { "value": "#4d5330", "usage": "CTA text and link color" }
  },
  "colorAlpha": {
    "card-border-default": { "value": "rgba(28,43,73,0.18)", "usage": "Card default border (navy @ 18%)" },
    "card-border-hover":   { "value": "rgba(28,43,73,0.4)",  "usage": "Card hover border (navy @ 40%)" },
    "card-shadow-hover":   { "value": "rgba(40,40,25,0.16)", "usage": "Card hover drop shadow" },
    "icon-shadow":         { "value": "rgba(40,40,25,0.18)", "usage": "Icon drop shadow" }
  },
  "gradient": {
    "page-background": {
      "value": "radial-gradient(120% 90% at 50% 0%, #f6eed7 0%, #efe5c9 60%, #e9ddbe 100%)",
      "usage": "Body background, referencing bg-parchment-start/mid/end"
    }
  },
  "font": {
    "display": {
      "family": "Cormorant Garamond",
      "role": "Headlines, scripture quotes, card titles",
      "weights": [400, 500, 600],
      "styles": ["normal", "italic"],
      "googleFontsName": "Cormorant Garamond"
    },
    "body": {
      "family": "EB Garamond",
      "role": "Labels, descriptions, footer, default body text",
      "weights": [400, 500],
      "googleFontsName": "EB Garamond",
      "fallback": "\"Times New Roman\", serif"
    }
  }
}
